# BasicFruitFlow

main: kit: flow: BasicFruitFlow:
{
  entity: "fruit",
  kind: "basic",
  name: "BasicFruitFlow",
  step: [
    {
      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "fruit_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "fruit_ref01",
        srcdatavar: "fruit_ref01_data",
        suffix: "_up0",
        textfield: "family"
      }

      op: "update",
      spec: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-fruit_ref01"
          }
        }
      ]
    }

    {
      input: {
        ref: "fruit_ref01",
        srcdatavar: "fruit_ref01_data",
        suffix: "_dt0"
      }

      match: {
        id: "fruit01"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-fruit_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicFruitFlow"
}